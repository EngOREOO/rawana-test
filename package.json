{
  "name": "figma-carousel",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "concurrently -k -n BACKEND,FRONTEND -c cyan,green \"npm run server:backend\" \"npm run server:frontend\"",
    "server:backend": "npm --prefix backend run start",
    "server:frontend": "vite --host 127.0.0.1 --port 5173",
    "server:start": "npm run server:backend",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@tinymce/tinymce-react": "^6.3.0",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.6",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.1",
    "tinymce": "^7.9.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "jsdom": "^27.0.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vitest": "^3.2.4",
    "concurrently": "^9.2.1"
  }
}
